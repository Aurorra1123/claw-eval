# claw-eval local secrets / config — copy to .env.local and fill in.
# .env.local is gitignored and auto-loaded by `claw-eval` (existing env wins).

# --- LLM ---
OPENROUTER_API_KEY=sk-or-...

# --- Real web search (Novada) ---
# Provider backend:
#   novada_sync  -> legacy GET https://scraperapi.novada.com/search (old api_key style)
#   novada_async -> current  POST https://scraper.novada.com/request (Bearer; new dashboard keys)
# New dashboard keys ONLY work with novada_async; the legacy endpoint returns
# HTTP 200 {"code":402,"msg":"Api Key error..."} which now surfaces as an error
# instead of a silent empty result set.
SERP_PROVIDER=novada_async
SERP_API_URL=https://scraper.novada.com/request
SERP_DEV_KEY=<novada dashboard key>

# Async scraper pairing — keep these together; scraper_name MUST be google.com
# when scraper_id=google_search (amazon.com from Novada's examples fails here).
NOVADA_SCRAPER_NAME=google.com
NOVADA_SCRAPER_ID=google_search
